<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="appRoot" styleClass="main-container"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <BorderPane styleClass="main-container">
        <!-- Main Scrollable Content (Home) -->
        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="mobile-content-scroll">
                <content>
                    <VBox spacing="20" styleClass="mobile-content">
                        <padding><Insets top="24" bottom="120" left="16" right="16" /></padding>
                        
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <Label text="Good morning!" styleClass="mobile-dashboard-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button styleClass="icon-button-gear" onAction="#handleOpenSettings" />
                            <Region minWidth="16" />
                            <Button styleClass="icon-button-bell" />
                        </HBox>

                        <!-- Jump back in -->
                        <VBox spacing="10">
                            <Label text="Jump back in" styleClass="mobile-section-heading" />
                            <FlowPane hgap="10" vgap="10" prefWrapLength="400">
                                <HBox styleClass="mobile-jump-card" prefWidth="180">
                                    <Region styleClass="jump-art-chill" minWidth="60" minHeight="60" />
                                    <VBox alignment="CENTER_LEFT" spacing="2" styleClass="jump-text-box">
                                        <Label text="Chill" styleClass="jump-title" />
                                        <Label text="Your Top Mixes" styleClass="jump-subtitle" />
                                    </VBox>
                                </HBox>
                                <HBox styleClass="mobile-jump-card" prefWidth="180">
                                    <Region styleClass="jump-art-indie" minWidth="60" minHeight="60" />
                                    <VBox alignment="CENTER_LEFT" spacing="2" styleClass="jump-text-box">
                                        <Label text="Indie" styleClass="jump-title" />
                                        <Label text="Your Top Mixes" styleClass="jump-subtitle" />
                                    </VBox>
                                </HBox>
                                <HBox styleClass="mobile-jump-card" prefWidth="180">
                                    <Region styleClass="jump-art-pop" minWidth="60" minHeight="60" />
                                    <VBox alignment="CENTER_LEFT" spacing="2" styleClass="jump-text-box">
                                        <Label text="Pop" styleClass="jump-title" />
                                        <Label text="Your Top Mixes" styleClass="jump-subtitle" />
                                    </VBox>
                                </HBox>
                                <HBox styleClass="mobile-jump-card" prefWidth="180">
                                    <Region styleClass="jump-art-workout" minWidth="60" minHeight="60" />
                                    <VBox alignment="CENTER_LEFT" spacing="2" styleClass="jump-text-box">
                                        <Label text="Workout" styleClass="jump-title" />
                                        <Label text="High Energy" styleClass="jump-subtitle" />
                                    </VBox>
                                </HBox>
                            </FlowPane>
                        </VBox>

                        <!-- Discover & Releases -->
                        <HBox spacing="12">
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Daily Discover" styleClass="mobile-section-heading" />
                                <VBox styleClass="mobile-hero-card discover-card-gradient" minHeight="160">
                                    <Region VBox.vgrow="ALWAYS" />
                                    <Label text="Discover Weekly" styleClass="hero-card-title" />
                                </VBox>
                            </VBox>
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="New Releases" styleClass="mobile-section-heading" />
                                <HBox spacing="10">
                                    <VBox styleClass="release-card">
                                        <Region styleClass="release-art-taylor" minWidth="80" minHeight="80" />
                                        <Label text="Taylor Swift" styleClass="release-title" />
                                        <Label text="'The Eras Tour...'" styleClass="release-subtitle" />
                                    </VBox>
                                    <VBox styleClass="release-card">
                                        <Region styleClass="release-art-olivia" minWidth="80" minHeight="80" />
                                        <Label text="Olivia Rodrigo" styleClass="release-title" />
                                        <Label text="- GUTS" styleClass="release-subtitle" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- Your playlists -->
                        <VBox spacing="10">
                            <Label text="Your playlists" styleClass="mobile-section-heading" />
                            <HBox spacing="12">
                                <VBox styleClass="playlist-vertical-card">
                                    <StackPane styleClass="playlist-art playlist-grad-liked" minWidth="120" minHeight="120">
                                        <Region styleClass="icon-heart" />
                                    </StackPane>
                                    <Label text="Liked Songs" styleClass="playlist-title" />
                                    <Label text="185 tracks" styleClass="playlist-subtitle" />
                                </VBox>
                                <VBox styleClass="playlist-vertical-card">
                                    <Region styleClass="playlist-art playlist-art-lofi" minWidth="120" minHeight="120" />
                                    <Label text="Lo-fi Beats" styleClass="playlist-title" />
                                    <Label text="Art tracks" styleClass="playlist-subtitle" />
                                </VBox>
                                <VBox styleClass="playlist-vertical-card">
                                    <Region styleClass="playlist-art playlist-art-gym" minWidth="120" minHeight="120" />
                                    <Label text="Gym Playlist" styleClass="playlist-title" />
                                    <Label text="Act Insight" styleClass="playlist-subtitle" />
                                </VBox>
                            </HBox>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>
        </center>

        <!-- Floating Bottom Dock Container -->
        <bottom>
            <VBox styleClass="floating-dock-wrapper" spacing="0">
                <padding><Insets bottom="12" left="12" right="12" /></padding>
                
                <!-- Floating Mini Player Island -->
                <VBox styleClass="mini-player-island">
                    <!-- Progress Line at Top -->
                    <ProgressBar fx:id="miniProgressLine" progress="0.0" prefHeight="2" maxWidth="-1" styleClass="mini-progress-line" />
                    
                    <HBox fx:id="mobilePlayerDock" styleClass="mobile-mini-player-inner" alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="mini-art-shell">
                            <ImageView fx:id="albumArtView" fitHeight="44" fitWidth="44" preserveRatio="true" styleClass="mini-album-art" />
                        </StackPane>
                        
                        <VBox alignment="CENTER_LEFT" spacing="1" HBox.hgrow="ALWAYS">
                            <Label fx:id="songTitleLabel" text="No song selected" styleClass="mini-song-title" />
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="artistLabel" text="Play a track" styleClass="mini-artist-name" />
                                <Label text="|" styleClass="mini-time-divider" />
                                <Label fx:id="mTimeC" text="0:00" styleClass="mini-time-label" />
                                <Label text="/" styleClass="mini-time-divider" />
                                <Label fx:id="mTimeT" text="0:00" styleClass="mini-time-label" />
                            </HBox>
                        </VBox>
                        
                        <Button fx:id="playPauseButton" styleClass="mini-play-button-v2" onAction="#handlePlayPause" />
                        <Button styleClass="mini-next-button-v2" onAction="#handleNext" />
                        <Region minWidth="4" />
                    </HBox>
                </VBox>

                <!-- Floating Navigation Island -->
                <HBox styleClass="mobile-nav-island" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS" styleClass="nav-item-active" onMouseClicked="#handleNavHome">
                        <Region styleClass="nav-icon-home" />
                        <Label text="Home" styleClass="nav-label" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS" styleClass="nav-item" onMouseClicked="#handleNavSearch">
                        <Region styleClass="nav-icon-search" />
                        <Label text="Search" styleClass="nav-label" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS" styleClass="nav-item" onMouseClicked="#handleNavLibrary">
                        <Region styleClass="nav-icon-library" />
                        <Label text="Library" styleClass="nav-label" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS" styleClass="nav-item" onMouseClicked="#handleNavPremium">
                        <Region styleClass="nav-icon-premium" />
                        <Label text="Premium" styleClass="nav-label" />
                    </VBox>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>



    <!-- Search Overlay -->
    <StackPane fx:id="mobileSearchOverlay" styleClass="mobile-search-overlay" visible="false" managed="false">
        <VBox styleClass="mobile-search-bg" spacing="0">
            <HBox alignment="CENTER" styleClass="search-top-bar" spacing="10">
                <padding><Insets top="20" bottom="16" left="16" right="16" /></padding>
                <Label text="Search" styleClass="search-title-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="icon-button-close" onAction="#handleNavHome" />
            </HBox>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="mobile-content-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="20" styleClass="search-content">
                        <padding><Insets left="16" right="16" bottom="100" /></padding>
                        
                        <HBox alignment="CENTER_LEFT" styleClass="search-input-box">
                            <Region styleClass="icon-search-small" />
                            <TextField fx:id="searchField" promptText="Artists, songs, or podcasts" styleClass="search-field" HBox.hgrow="ALWAYS" />
                            <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" maxHeight="20" maxWidth="20" />
                        </HBox>
                        
                        <!-- Search History & Queue hooks -->
                        <VBox fx:id="searchHistorySection" visible="false" managed="false" />
                        <FlowPane fx:id="searchHistoryContainer" visible="false" managed="false" />
                        <ListView fx:id="searchResultsList" styleClass="mobile-search-results-list" visible="false" managed="false" VBox.vgrow="ALWAYS" minHeight="400" />
                        <ListView fx:id="playlistView" styleClass="invisible-hooks" visible="false" managed="false" />
                        
                        <!-- Static Categories Grid matching Image 3 -->
                        <FlowPane fx:id="searchCategoriesBox" hgap="12" vgap="12">
                            <VBox styleClass="cat-gray" prefWidth="180" minHeight="110">
                                <Label text="Browse All" styleClass="cat-title" />
                                <Region styleClass="cat-icon-grid" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-red" prefWidth="180" minHeight="110">
                                <Label text="New Releases" styleClass="cat-title" />
                                <Region styleClass="cat-icon-star" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-teal" prefWidth="180" minHeight="110">
                                <Label text="Charts" styleClass="cat-title" />
                                <Region styleClass="cat-icon-chart" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-blue" prefWidth="180" minHeight="110">
                                <Label text="Made For You" styleClass="cat-title" />
                                <Label text="personalized" styleClass="cat-subtitle" />
                                <Region styleClass="cat-icon-profile" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-green" prefWidth="180" minHeight="110">
                                <Label text="Podcasts" styleClass="cat-title" />
                                <Region styleClass="cat-icon-mic" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-yellow" prefWidth="180" minHeight="110">
                                <Label text="Moods" styleClass="cat-title" />
                                <Region styleClass="cat-icon-weather" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-purple" prefWidth="180" minHeight="110">
                                <Label text="Decades" styleClass="cat-title" />
                                <Region styleClass="cat-icon-years" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-orange" prefWidth="180" minHeight="110">
                                <Label text="Live Events" styleClass="cat-title" />
                                <Region styleClass="cat-icon-ticket" VBox.vgrow="ALWAYS" />
                            </VBox>
                            <VBox styleClass="cat-indigo" prefWidth="180" minHeight="110">
                                <Label text="Genres" styleClass="cat-title" />
                                <Region styleClass="cat-icon-drums" VBox.vgrow="ALWAYS" />
                            </VBox>
                        </FlowPane>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </StackPane>

    <!-- Settings Overlay -->
    <StackPane fx:id="settingsOverlay" styleClass="mobile-settings-overlay" visible="false" managed="false">
        <VBox fx:id="settingsContainer" styleClass="settings-shell mobile-settings-full" spacing="0">
            <!-- Header -->
            <HBox alignment="CENTER" styleClass="settings-top-bar">
                <Button text="&lt;" styleClass="settings-back-btn" onAction="#handleDismissSettingsOverlay" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Settings" styleClass="settings-main-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="icon-button-close" onAction="#handleDismissSettingsOverlay" />
            </HBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="mobile-content-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox styleClass="settings-list-container">
                        
                        <!-- Account -->
                        <HBox styleClass="settings-list-item" alignment="CENTER_LEFT" spacing="12">
                            <Circle fill="#FFAAAA" radius="24" styleClass="profile-pic-ph" />
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Account" styleClass="set-item-title" />
                                <Label text="Premium Account" styleClass="set-item-sub" />
                            </VBox>
                            <Region styleClass="icon-chevron-right" />
                        </HBox>
                        
                        <!-- Settings Sections based on Image 2 -->
                        <Label text="Preferences" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Audio Quality" styleClass="set-item-title" />
                                <Label text="Streaming: Very High&#10;Downloads: Very High" styleClass="set-item-sub" />
                            </VBox>
                            <Label text="Auto-Quality" styleClass="set-item-val" />
                            <Region styleClass="set-toggle-off" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Equalizer" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Label text="Off" styleClass="set-item-val" />
                            <Region styleClass="set-toggle-off" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Gapless Playback" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Label text="ON" styleClass="set-item-val" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>
                        <VBox styleClass="settings-list-item" spacing="8">
                            <Label text="Crossfade" styleClass="set-item-title" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="3s" styleClass="set-item-val" />
                                <ProgressBar progress="0.3" HBox.hgrow="ALWAYS" styleClass="set-slider" />
                            </HBox>
                        </VBox>

                        <Label text="Data &amp; Storage" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Cellular Streaming" styleClass="set-item-title" />
                                <Label text="Very High" styleClass="set-item-sub" />
                            </VBox>
                            <Label text="Auto-Quality" styleClass="set-item-val" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Manage Downloads" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Label text="5.2 GB downloaded" styleClass="set-item-val" />
                            <Region styleClass="icon-chevron-right" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Clear Cache" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Label text="1.1 GB" styleClass="set-item-sub" />
                            <Label text="Details" styleClass="set-item-val" />
                        </HBox>

                        <Label text="Notifications" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item">
                            <Label text="New Releases" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Artist Updates" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-off" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Playlist Adds" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Concert Alerts" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>

                        <Label text="Social" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item">
                            <Label text="Show Listening Activity" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-on" />
                        </HBox>
                        <HBox styleClass="settings-list-item">
                            <Label text="Show Follower Count" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="set-toggle-off" />
                        </HBox>

                        <Label text="Devices" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item">
                            <Label text="Manage Connected Devices" styleClass="set-item-title" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Region styleClass="icon-chevron-right" />
                        </HBox>

                        <Label text="About" styleClass="set-section-label" />
                        <HBox styleClass="settings-list-item" spacing="12">
                            <Label text="App Version 1.8.0" styleClass="set-item-sub" />
                            <Label text="Terms of Service" styleClass="set-item-sub" />
                            <Label text="Privacy Policy" styleClass="set-item-sub" />
                        </HBox>
                        
                        <Button text="Log Out" styleClass="settings-logout-btn" maxWidth="Infinity" />
                        
                        <Region minHeight="40" />
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </StackPane>

    <!-- Now Playing Overlay (Spotify Style) -->
    <StackPane fx:id="mobileNowPlayingOverlay" styleClass="mobile-now-playing-overlay" visible="false" managed="false">
        <VBox styleClass="mobile-now-playing-screen" spacing="0">
            <!-- Header -->
            <HBox alignment="CENTER" styleClass="now-playing-header">
                <Button text="v" styleClass="icon-button-chevron-down" onAction="#handleCloseNowPlaying" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Now Playing" styleClass="now-playing-top-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="icon-button-dots" onAction="#handleOpenSettings" /> <!-- Reusing settings for now -->
            </HBox>

            <Region VBox.vgrow="ALWAYS" /> <!-- Spacing -->

            <!-- Album Art -->
            <StackPane styleClass="now-playing-art-container">
                <ImageView fx:id="expandedAlbumArtView" fitHeight="340.0" fitWidth="340.0" preserveRatio="true" styleClass="now-playing-art" />
            </StackPane>

            <Region VBox.vgrow="ALWAYS" /> <!-- Spacing -->

            <!-- Song Info & Heart -->
            <HBox alignment="BOTTOM_LEFT" styleClass="now-playing-info-row">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label fx:id="expandedSongTitleLabel" text="Los Angeles" styleClass="now-playing-title" wrapText="true" />
                    <Label fx:id="expandedArtistLabel" text="The Midnight" styleClass="now-playing-artist" />
                </VBox>
                <Region styleClass="icon-heart-active" />
                <Region minWidth="16" />
                <Region styleClass="icon-share" />
            </HBox>

            <!-- Progress Bar -->
            <VBox styleClass="now-playing-progress-section" spacing="8">
                <!-- Using a Slider for the progress to get the track/thumb look -->
                <Slider fx:id="expandedProgressSlider" styleClass="now-playing-slider" />
                <!-- Keeping the ProgressBar as fallback or invisible if controller relies on it, but we'll try to style the slider -->
                <ProgressBar fx:id="expandedProgressBar" progress="0.0" visible="false" managed="false" />
                
                <HBox alignment="CENTER">
                    <Label fx:id="expandedCurrentTimeLabel" text="0:00" styleClass="now-playing-time" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="expandedTotalTimeLabel" text="-0:00" styleClass="now-playing-time" />
                </HBox>
            </VBox>

            <!-- Transport Controls -->
            <HBox alignment="CENTER" styleClass="now-playing-transport" spacing="24">
                <Button styleClass="icon-button-shuffle" onAction="#handleToggleShuffle" />
                <Button styleClass="icon-button-prev" onAction="#handlePrevious" />
                <Button fx:id="expandedPlayPauseButton" styleClass="now-playing-play-btn" onAction="#handlePlayPause" />
                <Button styleClass="icon-button-next" onAction="#handleNext" />
                <Button styleClass="icon-button-repeat" onAction="#handleToggleRepeat" />
            </HBox>
            
            <HBox styleClass="now-playing-bottom-row" alignment="CENTER_LEFT" spacing="16">
                <Region styleClass="icon-devices" />
                <Region HBox.hgrow="ALWAYS" />
                <Region styleClass="icon-share" />
                <Region styleClass="icon-playlist-add" />
            </HBox>

            <!-- Lyrics Panel -->
            <VBox styleClass="now-playing-lyrics-panel" VBox.vgrow="ALWAYS" maxHeight="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Lyrics" styleClass="lyrics-panel-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="expandedLyricsBadgeLabel" styleClass="lyrics-badge-styled" />
                    <Region styleClass="icon-expand" />
                </HBox>
                
                <VBox spacing="4" VBox.vgrow="ALWAYS">
                    <Label fx:id="lyricsHeadlineLabel" styleClass="lyrics-headline-mobile" />
                    <Label fx:id="lyricsSourceLabel" styleClass="lyrics-source-mobile" />
                    <ScrollPane fx:id="lyricsScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" styleClass="lyrics-scroll-mobile" VBox.vgrow="ALWAYS">
                        <VBox fx:id="lyricsContainer" styleClass="lyrics-container-mobile" spacing="8" />
                    </ScrollPane>
                </VBox>
            </VBox>
            
            <Label fx:id="userInfoLabel" visible="false" managed="false" />
            <Button fx:id="menuButton" visible="false" managed="false" />
            
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </StackPane>

    <Label fx:id="statusLabel" visible="true" managed="true" 
           StackPane.alignment="TOP_CENTER" styleClass="status-label-diagnostic" text="App Ready - Select Song">
        <StackPane.margin><Insets top="40"/></StackPane.margin>
    </Label>
</StackPane>



