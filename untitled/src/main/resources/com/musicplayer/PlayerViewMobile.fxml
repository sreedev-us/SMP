<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="appRoot" styleClass="main-container"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <BorderPane styleClass="main-container">
        <top>
            <VBox spacing="10">
                <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets left="18" right="18" top="10" bottom="10" /></padding>
                    <Button fx:id="menuButton" text="Browse" styleClass="menu-toggle-button"
                            onAction="#handleToggleSidebar" />
                    <Label text="HP" styleClass="header-logo" />
                    <Label text="Harmony Pro" styleClass="header-title" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Label fx:id="userInfoLabel" text="Not Logged In" styleClass="user-info-label" />
                </HBox>

                <VBox fx:id="sidebar" styleClass="sidebar" spacing="12">
                    <padding><Insets top="0" left="18" right="18" bottom="12" /></padding>
                    <Label text="SEARCH" styleClass="section-label" />
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="Search YouTube..."
                                   styleClass="search-field" HBox.hgrow="ALWAYS"
                                   onAction="#handleSearch" />
                        <Button text="Go" styleClass="search-btn" onAction="#handleSearch" />
                    </HBox>
                    <VBox fx:id="searchHistorySection" spacing="8" visible="false" managed="false">
                        <Label text="RECENT SEARCHES" styleClass="section-label" />
                        <FlowPane fx:id="searchHistoryContainer" hgap="8" vgap="8" />
                    </VBox>
                    <ListView fx:id="searchResultsList" styleClass="results-list" prefHeight="160" />
                    <Button text="Add without Playing" styleClass="add-button"
                            maxWidth="Infinity" onAction="#handleAddSearchResult" />
                    <Label text="YOUR QUEUE" styleClass="section-label" />
                    <ListView fx:id="playlistView" styleClass="playlist-view" prefHeight="140" />
                </VBox>
            </VBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="lyrics-scroll-pane">
                <content>
                    <VBox spacing="18">
                        <padding><Insets top="20" bottom="20" left="20" right="20" /></padding>

                        <VBox styleClass="now-playing-card" alignment="CENTER" spacing="18">
                            <StackPane>
                                <ImageView fx:id="albumArtView"
                                           fitHeight="240.0" fitWidth="240.0"
                                           preserveRatio="true" styleClass="album-art" />
                                <ProgressIndicator fx:id="loadingIndicator" prefWidth="54" prefHeight="54"
                                                   styleClass="loading-indicator" visible="false" />
                            </StackPane>
                            <Label fx:id="songTitleLabel" text="No song selected"
                                   styleClass="song-title-label" wrapText="true" maxWidth="420" />
                            <Label fx:id="artistLabel" text="Search for a song and click to play"
                                   styleClass="artist-label" />
                        </VBox>

                        <VBox styleClass="lyrics-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="LIVE LYRICS" styleClass="lyrics-section-label" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lyricsSourceLabel" text="Waiting for a song" styleClass="lyrics-source-label" />
                            </HBox>
                            <Label fx:id="lyricsHeadlineLabel" text="Lyrics will appear here"
                                   styleClass="lyrics-headline-label" wrapText="true" />
                            <ScrollPane fx:id="lyricsScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                                        pannable="true" styleClass="lyrics-scroll-pane" prefHeight="260">
                                <content>
                                    <VBox fx:id="lyricsContainer" styleClass="lyrics-container" spacing="12" />
                                </content>
                            </ScrollPane>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>

        <bottom>
            <VBox styleClass="player-controls" alignment="CENTER" spacing="12">
                <padding><Insets top="14" bottom="18" left="20" right="20" /></padding>

                <HBox alignment="CENTER" spacing="12">
                    <Label fx:id="currentTimeLabel" text="0:00" styleClass="time-label" />
                    <ProgressBar fx:id="progressBar" HBox.hgrow="ALWAYS" progress="0.0" />
                    <Label fx:id="totalTimeLabel" text="0:00" styleClass="time-label" />
                </HBox>

                <HBox alignment="CENTER" spacing="12">
                    <Button fx:id="shuffleButton" text="Mix" styleClass="icon-button"
                            onAction="#handleToggleShuffle" />
                    <Button fx:id="autoRadioButton" text="Auto" styleClass="icon-button"
                            onAction="#handleToggleAutoRadio" />
                    <Button text="|&lt;" styleClass="icon-button" onAction="#handlePrevious" />
                    <Button fx:id="playPauseButton" text="|>" styleClass="play-pause-button"
                            onAction="#handlePlayPause" />
                    <Button text="&gt;|" styleClass="icon-button" onAction="#handleNext" />
                    <Button fx:id="repeatButton" text="Loop" styleClass="icon-button"
                            onAction="#handleToggleRepeat" />
                </HBox>

                <HBox alignment="CENTER" spacing="12">
                    <Button text="Vol -" styleClass="icon-button" onAction="#handleVolumeDown" />
                    <Button text="Vol +" styleClass="icon-button" onAction="#handleVolumeUp" />
                    <Button fx:id="hostButton" text="Start Sync" styleClass="icon-button"
                            onAction="#handleHostSession" />
                    <Button fx:id="joinButton" text="Connect" styleClass="icon-button"
                            onAction="#handleJoinSession" />
                </HBox>

                <TextField fx:id="publicLinkField" visible="false" managed="false" editable="false"
                           promptText="Generating link..." />
                <Label fx:id="peerCountLabel" text="" styleClass="user-info-label" />
                <Label fx:id="statusLabel" text="Welcome to Harmony Pro!"
                       styleClass="status-label" />
            </VBox>
        </bottom>
    </BorderPane>

    <StackPane fx:id="settingsOverlay" visible="false" managed="false" />
</StackPane>
