<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="appRoot" styleClass="main-container"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <BorderPane styleClass="main-container">
        <top>
            <VBox spacing="12" styleClass="mobile-top-shell">
                <HBox styleClass="header-bar mobile-header-bar" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets left="18" right="18" top="10" bottom="10" /></padding>
                    <Button fx:id="menuButton" text="Browse" styleClass="mobile-header-button"
                            onAction="#handleToggleSidebar" />
                    <Label text="HP" styleClass="header-logo" />
                    <VBox spacing="2">
                        <Label text="Harmony Pro" styleClass="header-title" />
                        <Label fx:id="userInfoLabel" text="Not Logged In" styleClass="user-info-label mobile-user-badge" />
                    </VBox>
                    <HBox HBox.hgrow="ALWAYS" />
                    <Button text="Tune" styleClass="mobile-header-button mobile-settings-trigger"
                            onAction="#handleOpenSettings" />
                </HBox>

                <VBox fx:id="sidebar" styleClass="sidebar mobile-browser-panel" spacing="14">
                    <padding><Insets top="0" left="18" right="18" bottom="16" /></padding>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="Search YouTube..."
                                   styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <Button text="Go" styleClass="search-btn" onAction="#handleSearch" />
                    </HBox>
                    <VBox fx:id="searchHistorySection" spacing="8" visible="false" managed="false">
                        <Label text="RECENT SEARCHES" styleClass="section-label" />
                        <FlowPane fx:id="searchHistoryContainer" hgap="8" vgap="8" />
                    </VBox>
                    <VBox styleClass="mobile-pane-card" spacing="8">
                        <Label text="RESULTS" styleClass="section-label" />
                        <ListView fx:id="searchResultsList" styleClass="results-list mobile-results-list" prefHeight="168" />
                    </VBox>
                    <Button text="Add without Playing" styleClass="add-button mobile-wide-button"
                            maxWidth="Infinity" onAction="#handleAddSearchResult" />
                    <VBox styleClass="mobile-pane-card" spacing="8">
                        <Label text="QUEUE" styleClass="section-label" />
                        <ListView fx:id="playlistView" styleClass="playlist-view mobile-results-list" prefHeight="132" />
                    </VBox>
                </VBox>
            </VBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="lyrics-scroll-pane mobile-content-scroll">
                <content>
                    <VBox spacing="18" styleClass="mobile-content">
                        <padding><Insets top="18" bottom="18" left="18" right="18" /></padding>

                        <VBox styleClass="now-playing-card mobile-now-playing-card" alignment="CENTER" spacing="16">
                            <StackPane styleClass="mobile-art-shell">
                                <ImageView fx:id="albumArtView"
                                           fitHeight="208.0" fitWidth="208.0"
                                           preserveRatio="true" styleClass="album-art" />
                                <ProgressIndicator fx:id="loadingIndicator" prefWidth="48" prefHeight="48"
                                                   styleClass="loading-indicator" visible="false" />
                            </StackPane>
                            <Label fx:id="songTitleLabel" text="No song selected"
                                   styleClass="song-title-label mobile-song-title" wrapText="true" maxWidth="420" />
                            <Label fx:id="artistLabel" text="Search for a song and click to play"
                                   styleClass="artist-label mobile-artist-label" />
                        </VBox>

                        <VBox styleClass="lyrics-card mobile-lyrics-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="LIVE LYRICS" styleClass="lyrics-section-label" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lyricsSourceLabel" text="Waiting for a song" styleClass="lyrics-source-label" />
                            </HBox>
                            <Label fx:id="lyricsHeadlineLabel" text="Lyrics will appear here"
                                   styleClass="lyrics-headline-label" wrapText="true" />
                            <ScrollPane fx:id="lyricsScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                                        pannable="true" styleClass="lyrics-scroll-pane" prefHeight="260">
                                <content>
                                    <VBox fx:id="lyricsContainer" styleClass="lyrics-container" spacing="12" />
                                </content>
                            </ScrollPane>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>

        <bottom>
            <VBox styleClass="player-controls mobile-player-dock" alignment="CENTER" spacing="10">
                <padding><Insets top="12" bottom="16" left="18" right="18" /></padding>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-progress-row">
                    <Label fx:id="currentTimeLabel" text="0:00" styleClass="time-label" />
                    <ProgressBar fx:id="progressBar" HBox.hgrow="ALWAYS" progress="0.0" />
                    <Label fx:id="totalTimeLabel" text="0:00" styleClass="time-label" />
                </HBox>

                <HBox alignment="CENTER" spacing="12" styleClass="mobile-transport-row">
                    <Button text="|&lt;" styleClass="icon-button mobile-transport-button" onAction="#handlePrevious" />
                    <Button fx:id="playPauseButton" text="|>" styleClass="play-pause-button mobile-play-pause-button"
                            onAction="#handlePlayPause" />
                    <Button text="&gt;|" styleClass="icon-button mobile-transport-button" onAction="#handleNext" />
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-mode-row">
                    <Button fx:id="shuffleButton" text="Mix" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleShuffle" />
                    <Button fx:id="autoRadioButton" text="Auto" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleAutoRadio" />
                    <Button fx:id="repeatButton" text="Loop" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleRepeat" />
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-utility-row">
                    <Button text="Vol -" styleClass="icon-button mobile-mini-button" onAction="#handleVolumeDown" />
                    <Button text="Vol +" styleClass="icon-button mobile-mini-button" onAction="#handleVolumeUp" />
                </HBox>

                <TextField fx:id="publicLinkField" visible="false" managed="false" editable="false"
                           promptText="Generating link..." />
                <Label fx:id="peerCountLabel" text="" styleClass="user-info-label" visible="false" managed="false" />
                <Label fx:id="statusLabel" text="Welcome to Harmony Pro!"
                       styleClass="status-label mobile-status-label" wrapText="true" />
            </VBox>
        </bottom>
    </BorderPane>

    <StackPane fx:id="settingsOverlay" styleClass="overlay-backdrop mobile-settings-overlay"
               visible="false" managed="false" onMouseClicked="#handleDismissSettingsOverlay">
        <VBox fx:id="settingsContainer" styleClass="settings-shell mobile-settings-shell"
              onMouseClicked="#handleConsumeOverlayClick" maxWidth="480" />
    </StackPane>
</StackPane>
