<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="appRoot" styleClass="main-container"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <BorderPane styleClass="main-container">
        <top>
            <HBox styleClass="header-bar mobile-header-bar" alignment="CENTER_LEFT" spacing="10">
                <padding><Insets left="18" right="18" top="10" bottom="10" /></padding>
                <Button fx:id="menuButton" text="Browse" styleClass="mobile-header-button"
                        onAction="#handleToggleSidebar" />
                <Label text="HP" styleClass="header-logo mobile-wordmark" />
                <VBox spacing="2">
                    <Label text="Harmony Pro" styleClass="header-title" />
                    <Label text="Mobile Listening Suite" styleClass="mobile-subtitle" />
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <Label fx:id="userInfoLabel" text="Not Logged In" styleClass="user-info-label mobile-user-badge" />
                <Button text="Tune" styleClass="mobile-header-button mobile-settings-trigger"
                        onAction="#handleOpenSettings" />
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="lyrics-scroll-pane mobile-content-scroll">
                <content>
                    <VBox spacing="18" styleClass="mobile-content">
                        <padding><Insets top="18" bottom="18" left="18" right="18" /></padding>

                        <VBox spacing="14" styleClass="mobile-dashboard-section">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="Good morning!" styleClass="mobile-dashboard-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="Search" styleClass="mobile-ghost-button"
                                        onAction="#handleToggleSidebar" />
                            </HBox>

                            <Label text="Jump back in" styleClass="mobile-section-heading" />
                            <FlowPane hgap="10" vgap="10" prefWrapLength="420" styleClass="mobile-shortcut-grid">
                                <VBox styleClass="mobile-shortcut-card shortcut-card-ocean" prefWidth="186" spacing="6">
                                    <Label text="Chill Mix" styleClass="mobile-shortcut-title" />
                                    <Label text="Your top mixes" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                                <VBox styleClass="mobile-shortcut-card shortcut-card-indigo" prefWidth="186" spacing="6">
                                    <Label text="Indie Nights" styleClass="mobile-shortcut-title" />
                                    <Label text="Fresh finds" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                                <VBox styleClass="mobile-shortcut-card shortcut-card-rose" prefWidth="186" spacing="6">
                                    <Label text="Pop Blend" styleClass="mobile-shortcut-title" />
                                    <Label text="Top releases" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                                <VBox styleClass="mobile-shortcut-card shortcut-card-forest" prefWidth="186" spacing="6">
                                    <Label text="Workout Run" styleClass="mobile-shortcut-title" />
                                    <Label text="Keep moving" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                            </FlowPane>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Daily Discover" styleClass="mobile-section-heading" />
                                <Label text="New Releases" styleClass="mobile-section-heading" />
                            </HBox>
                            <HBox spacing="10">
                                <VBox styleClass="mobile-discovery-card discover-card-spectrum" HBox.hgrow="ALWAYS" spacing="10">
                                    <Label text="Discover Weekly" styleClass="mobile-shortcut-title" />
                                    <Label text="A new mix built around your listening." styleClass="mobile-shortcut-subtitle" wrapText="true" />
                                </VBox>
                                <VBox styleClass="mobile-discovery-card discover-card-spotlight" HBox.hgrow="ALWAYS" spacing="10">
                                    <Label text="Taylor Swift" styleClass="mobile-shortcut-title" />
                                    <Label text="Olivia Rodrigo, SZA, more" styleClass="mobile-shortcut-subtitle" wrapText="true" />
                                </VBox>
                            </HBox>

                            <Label text="Your playlists" styleClass="mobile-section-heading" />
                            <HBox spacing="10">
                                <VBox styleClass="mobile-playlist-card playlist-card-liked" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Liked Songs" styleClass="mobile-shortcut-title" />
                                    <Label text="193 tracks" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                                <VBox styleClass="mobile-playlist-card playlist-card-lofi" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Lo-fi Beats" styleClass="mobile-shortcut-title" />
                                    <Label text="Late hours" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                                <VBox styleClass="mobile-playlist-card playlist-card-gym" HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Gym Playlist" styleClass="mobile-shortcut-title" />
                                    <Label text="High energy" styleClass="mobile-shortcut-subtitle" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox styleClass="mobile-hero-card" spacing="18">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="mobile-hero-topline">
                                <Label text="Now Playing" styleClass="mobile-eyebrow" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="Search" styleClass="mobile-ghost-button"
                                        onAction="#handleToggleSidebar" />
                            </HBox>

                            <VBox styleClass="now-playing-card mobile-now-playing-card" alignment="CENTER" spacing="16">
                            <StackPane styleClass="mobile-art-shell">
                                <ImageView fx:id="albumArtView"
                                           fitHeight="220.0" fitWidth="220.0"
                                           preserveRatio="true" styleClass="album-art" />
                                <ProgressIndicator fx:id="loadingIndicator" prefWidth="48" prefHeight="48"
                                                   styleClass="loading-indicator" visible="false" />
                            </StackPane>
                            <Label fx:id="songTitleLabel" text="No song selected"
                                   styleClass="song-title-label mobile-song-title" wrapText="true" maxWidth="420" />
                            <Label fx:id="artistLabel" text="Search for a song and click to play"
                                   styleClass="artist-label mobile-artist-label" />
                            </VBox>

                            <HBox alignment="CENTER" spacing="10" styleClass="mobile-feature-strip">
                                <Label text="Smart Queue" styleClass="mobile-feature-pill" />
                                <Label text="Live Lyrics" styleClass="mobile-feature-pill" />
                                <Label text="YouTube Search" styleClass="mobile-feature-pill" />
                            </HBox>
                        </VBox>

                        <VBox styleClass="lyrics-card mobile-lyrics-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="LIVE LYRICS" styleClass="lyrics-section-label" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lyricsSourceLabel" text="Waiting for a song" styleClass="lyrics-source-label" />
                            </HBox>
                            <Label fx:id="lyricsHeadlineLabel" text="Lyrics will appear here"
                                   styleClass="lyrics-headline-label" wrapText="true" />
                            <ScrollPane fx:id="lyricsScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                                        pannable="true" styleClass="lyrics-scroll-pane" prefHeight="260">
                                <content>
                                    <VBox fx:id="lyricsContainer" styleClass="lyrics-container" spacing="12" />
                                </content>
                            </ScrollPane>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>

        <bottom>
            <VBox styleClass="player-controls mobile-player-dock" alignment="CENTER" spacing="10"
                  onMouseClicked="#handleOpenNowPlaying">
                <padding><Insets top="12" bottom="16" left="18" right="18" /></padding>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-progress-row">
                    <Label fx:id="currentTimeLabel" text="0:00" styleClass="time-label" />
                    <ProgressBar fx:id="progressBar" HBox.hgrow="ALWAYS" progress="0.0" />
                    <Label fx:id="totalTimeLabel" text="0:00" styleClass="time-label" />
                </HBox>

                <HBox alignment="CENTER" spacing="12" styleClass="mobile-transport-row">
                    <Button text="|&lt;" styleClass="icon-button mobile-transport-button" onAction="#handlePrevious" />
                    <Button fx:id="playPauseButton" text="|>" styleClass="play-pause-button mobile-play-pause-button"
                            onAction="#handlePlayPause" />
                    <Button text="&gt;|" styleClass="icon-button mobile-transport-button" onAction="#handleNext" />
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-mode-row">
                    <Button fx:id="shuffleButton" text="Mix" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleShuffle" />
                    <Button fx:id="autoRadioButton" text="Auto" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleAutoRadio" />
                    <Button fx:id="repeatButton" text="Loop" styleClass="icon-button mobile-pill-button"
                            onAction="#handleToggleRepeat" />
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="mobile-utility-row">
                    <Button text="Vol -" styleClass="icon-button mobile-mini-button" onAction="#handleVolumeDown" />
                    <Button text="Vol +" styleClass="icon-button mobile-mini-button" onAction="#handleVolumeUp" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="mobile-status-row">
                    <Label text="Status" styleClass="mobile-status-tag" />
                    <Label fx:id="statusLabel" text="Welcome to Harmony Pro!"
                           styleClass="status-label mobile-status-label" wrapText="true" />
                </HBox>

                <TextField fx:id="publicLinkField" visible="false" managed="false" editable="false"
                           promptText="Generating link..." />
                <Label fx:id="peerCountLabel" text="" styleClass="user-info-label" visible="false" managed="false" />
            </VBox>
        </bottom>
    </BorderPane>

    <StackPane fx:id="mobileSearchOverlay" styleClass="overlay-backdrop mobile-search-overlay"
               visible="false" managed="false">
        <VBox fx:id="sidebar" styleClass="sidebar mobile-search-shell" spacing="14" maxWidth="520">
            <padding><Insets top="18" left="18" right="18" bottom="18" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="mobile-search-header">
                <VBox spacing="2">
                    <Label text="Search &amp; Queue" styleClass="settings-card-title" />
                    <Label text="Find a track, then add it or tap a result to play." styleClass="settings-card-copy" />
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <Button text="Close" styleClass="mobile-header-button" onAction="#handleToggleSidebar" />
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search YouTube..."
                           styleClass="search-field" HBox.hgrow="ALWAYS" />
                <Button text="Go" styleClass="search-btn" onAction="#handleSearch" />
            </HBox>
            <VBox fx:id="searchHistorySection" spacing="8" visible="false" managed="false">
                <Label text="RECENT SEARCHES" styleClass="section-label" />
                <FlowPane fx:id="searchHistoryContainer" hgap="8" vgap="8" />
            </VBox>
            <VBox styleClass="mobile-pane-card" spacing="8">
                <Label text="RESULTS" styleClass="section-label" />
                <ListView fx:id="searchResultsList" styleClass="results-list mobile-results-list" prefHeight="220" />
            </VBox>
            <Button text="Add without Playing" styleClass="add-button mobile-wide-button"
                    onAction="#handleAddSearchResult" />
            <VBox styleClass="mobile-pane-card" spacing="8">
                <Label text="QUEUE" styleClass="section-label" />
                <ListView fx:id="playlistView" styleClass="playlist-view mobile-results-list" prefHeight="170" />
            </VBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="settingsOverlay" styleClass="overlay-backdrop mobile-settings-overlay"
               visible="false" managed="false">
        <VBox fx:id="settingsContainer" styleClass="settings-shell mobile-settings-shell" maxWidth="480" />
    </StackPane>

    <StackPane fx:id="mobileNowPlayingOverlay" styleClass="overlay-backdrop mobile-now-playing-overlay"
               visible="false" managed="false">
        <VBox styleClass="mobile-now-playing-screen" spacing="18">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="mobile-now-playing-header">
                <Button text="Done" styleClass="mobile-header-button" onAction="#handleCloseNowPlaying" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Now Playing" styleClass="mobile-now-playing-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Tune" styleClass="mobile-header-button" onAction="#handleOpenSettings" />
            </HBox>

            <StackPane styleClass="mobile-now-playing-art-shell">
                <ImageView fx:id="expandedAlbumArtView"
                           fitHeight="300.0" fitWidth="300.0"
                           preserveRatio="true" styleClass="album-art mobile-expanded-art" />
            </StackPane>

            <VBox alignment="CENTER_LEFT" spacing="6" styleClass="mobile-now-playing-copy">
                <Label fx:id="expandedSongTitleLabel" text="No song selected"
                       styleClass="mobile-expanded-song-title" wrapText="true" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="expandedArtistLabel" text="Select a song from the playlist"
                           styleClass="mobile-expanded-artist" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="expandedLyricsBadgeLabel" text="Waiting for track"
                           styleClass="mobile-expanded-badge" />
                </HBox>
            </VBox>

            <VBox spacing="10" styleClass="mobile-expanded-progress-shell">
                <ProgressBar fx:id="expandedProgressBar" progress="0.0" />
                <HBox alignment="CENTER" spacing="10">
                    <Label fx:id="expandedCurrentTimeLabel" text="0:00" styleClass="time-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="expandedTotalTimeLabel" text="0:00" styleClass="time-label" />
                </HBox>
            </VBox>

            <HBox alignment="CENTER" spacing="18" styleClass="mobile-expanded-transport-row">
                <Button text="Mix" styleClass="icon-button mobile-expanded-side-button" onAction="#handleToggleShuffle" />
                <Button text="|&lt;" styleClass="icon-button mobile-expanded-side-button" onAction="#handlePrevious" />
                <Button fx:id="expandedPlayPauseButton" text="|>" styleClass="play-pause-button mobile-expanded-play-button"
                        onAction="#handlePlayPause" />
                <Button text="&gt;|" styleClass="icon-button mobile-expanded-side-button" onAction="#handleNext" />
                <Button text="Loop" styleClass="icon-button mobile-expanded-side-button" onAction="#handleToggleRepeat" />
            </HBox>

            <HBox alignment="CENTER" spacing="12" styleClass="mobile-expanded-actions-row">
                <Button text="Search" styleClass="mobile-ghost-button" onAction="#handleToggleSidebar" />
                <Button text="Lyrics" styleClass="mobile-ghost-button" onAction="#handleCloseNowPlaying" />
                <Button text="Done" styleClass="mobile-ghost-button" onAction="#handleCloseNowPlaying" />
            </HBox>
        </VBox>
    </StackPane>
</StackPane>
